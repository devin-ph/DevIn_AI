# DevIn Configuration

# PRIMARY MODEL
# gemini-2.0-flash: 1,500 req/day
# gemini-2.5-flash: 20 req/day
# claude-haiku-3-5: best quality, paid
DEVIN_DEFAULT_MODEL=gemini-2.0-flash

# MULTI-MODEL (optional, falls back to DEFAULT)
DEVIN_ARCHITECT_MODEL=gemini-2.0-flash
DEVIN_WORKER_MODEL=gemini-2.0-flash
DEVIN_COMPANION_MODEL=gemini-2.0-flash

# FALLBACK CHAIN (tried in order if primary hits rate limit)
DEVIN_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-1.5-flash-latest

# API KEYS
GOOGLE_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY= 
GROQ_API_KEY=      

# AGENT BEHAVIOR
DEVIN_MAX_ITERATIONS=15
DEVIN_AUTO_APPROVE=false
DEVIN_LOG_LEVEL=WARNING
