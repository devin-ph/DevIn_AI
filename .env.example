# =============================================================================
# DevIn Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control!

# --- LLM Provider (FREE) ---
# Google Gemini — Free tier: 15 RPM, 1M tokens/day
# Get your free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Default model (free options: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-1.5-flash)
DEVIN_DEFAULT_MODEL=gemini-2.0-flash

# --- Optional Paid Providers (leave empty if not using) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Search ---
# DuckDuckGo is used by default (free, no key needed)
# Tavily is optional (has free tier: https://tavily.com)
TAVILY_API_KEY=

# --- Observability (Optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=devin
LANGSMITH_TRACING=false

# --- Safety ---
DEVIN_MAX_ITERATIONS=15
DEVIN_REQUIRE_CONFIRMATION=true

# --- Memory (Phase 3) ---
CHROMA_PERSIST_DIR=./data/chromadb
