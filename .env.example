# --- Primary LLM (Free) ---
# Google AI Studio: https://aistudio.google.com/apikey
# Free: 1500 req/day, 1M tokens/day
GOOGLE_API_KEY=your-gemini-api-key-here
DEVIN_DEFAULT_MODEL=gemini-2.5-flash
# Options: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-1.5-flash

# Multi-model configuration (optional — falls back to DEVIN_DEFAULT_MODEL)
DEVIN_ARCHITECT_MODEL=   # Best reasoning model you have
DEVIN_WORKER_MODEL=      # Fast cheap model for execution
DEVIN_COMPANION_MODEL=   # Model for life/companion chat

# --- Fallback LLM (Free, faster) ---
# Groq: https://console.groq.com
# Free: 14,400 req/day — best for testing
GROQ_API_KEY=your-groq-api-key-here

# --- Optional Paid Providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Search ---
# DuckDuckGo used by default (free, no key needed)
TAVILY_API_KEY=

# --- Agent Behavior ---
DEVIN_MAX_ITERATIONS=15
DEVIN_AUTO_APPROVE=false   # Set true to skip consent prompts (testing only)
DEVIN_LOG_LEVEL=WARNING    # Use DEBUG to diagnose issues

# --- Observability (Optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=devin
LANGSMITH_TRACING=false

# --- Memory ---
CHROMA_PERSIST_DIR=./data/chromadb